[Unit]
Description=Cloudflared Tunnel Watchdog for HomeVault
After=network-online.target cloudflared-tunnel.service
Wants=network-online.target cloudflared-tunnel.service

[Service]
Type=simple
WorkingDirectory=%h/server
Environment=PYTHONPATH=%h/server
EnvironmentFile=%h/server/.env
ExecStart=%h/server/venv/bin/python %h/server/scripts/tunnel_watchdog.py
Restart=always
RestartSec=10

[Install]
WantedBy=default.target
